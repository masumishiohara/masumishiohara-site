const projects = [
  {
    slug: "botanical-portraits",
    number: "01",
    title: "Botanical Portraits",
    subtitle: "Portraits of fruit, specimens, and still lifes",
    description:
      "White and black background works in which cultivated fruit is treated as portrait, specimen, and object. The series moves between botanical art, still life, and contemporary photographic observation.",
    cover: "/images/botanical-portraits/cover.jpg",
    images: Array.from({ length: 15 }, (_, i) => `/images/botanical-portraits/${String(i + 1).padStart(2, "0")}.jpg`)
  },
  {
    slug: "growth-process",
    number: "02",
    title: "Growth Process",
    subtitle: "Fruit, time, and seasonal transformation",
    description:
      "Works documenting the formation of pears, grapes, apples, and plums through the growing season. The images observe change, weight, color, labor, and the temporal structure of cultivation.",
    cover: "/images/growth-process/cover.jpg",
    images: Array.from({ length: 4 }, (_, i) => `/images/growth-process/${String(i + 1).padStart(2, "0")}.jpg`)
  },
  {
    slug: "sculptural-fruit",
    number: "03",
    title: "Sculptural Fruit",
    subtitle: "Organic form, intervention, gravity, and structure",
    description:
      "Fruit forms treated as sculptural objects. The series explores growth control, tension, deformation, gravity, and the boundary between agricultural practice and constructed form.",
    cover: "/images/sculptural-fruit/cover.jpg",
    images: Array.from({ length: 12 }, (_, i) => `/images/sculptural-fruit/${String(i + 1).padStart(2, "0")}.jpg`)
  },
  {
    slug: "parchment-on-vellum",
    number: "04",
    title: "Parchment on Vellum",
    subtitle: "Material, archive, and botanical memory",
    description:
      "Works printed and presented with a vellum-like material sensibility. The series connects fruit, horticultural classification, historical botanical illustration, and the physical presence of the print.",
    cover: "/images/parchment-on-vellum/cover.jpg",
    images: Array.from({ length: 5 }, (_, i) => `/images/parchment-on-vellum/${String(i + 1).padStart(2, "0")}.jpg`)
  },
  {
    slug: "breeding-archive",
    number: "05",
    title: "Breeding Archive",
    subtitle: "Selection, rejection, disappearance, and record",
    description:
      "A forthcoming archive of varieties and selections removed from advancement during the breeding process. The project considers cultivation as judgment, memory, and disappearance.",
    cover: "/images/breeding-archive/cover.jpg",
    images: Array.from({ length: 4 }, (_, i) => `/images/breeding-archive/${String(i + 1).padStart(2, "0")}.jpg`),
    note: "Archive in progress"
  }
];

function ProjectGallery({ project }: { project: typeof projects[number] }) {
  return (
    <section id={project.slug} className="border-t border-white/10 py-28 md:py-40">
      <div className="mx-auto max-w-7xl px-5 md:px-8">
        <div className="grid gap-12 md:grid-cols-[0.82fr_1.18fr] md:gap-20">
          <div className="md:sticky md:top-28 self-start">
            <p className="mb-8 text-[11px] uppercase tracking-[0.35em] text-white/35">
              {project.number} / Project
            </p>
            <h2 className="text-5xl font-extralight leading-none tracking-tight md:text-7xl">
              {project.title}
            </h2>
            <p className="mt-6 max-w-md text-sm uppercase tracking-[0.18em] text-white/35">
              {project.subtitle}
            </p>
            <p className="mt-10 max-w-md text-sm leading-8 text-white/58">
              {project.description}
            </p>
            {project.note && (
              <p className="mt-8 inline-block rounded-full border border-white/15 px-5 py-2 text-[10px] uppercase tracking-[0.24em] text-white/45">
                {project.note}
              </p>
            )}
          </div>

          <div className="grid gap-5 md:gap-8">
            <div className="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.03]">
              <img src={project.cover} alt={project.title} className="h-[70vh] w-full object-cover transition duration-[1800ms] hover:scale-[1.015]" />
            </div>

            <div className="grid grid-cols-2 gap-5 md:gap-8">
              {project.images.slice(1).map((src, index) => (
                <div key={src} className={`${index % 5 === 0 ? "col-span-2" : ""} overflow-hidden rounded-[1.4rem] border border-white/8 bg-white/[0.025]`}>
                  <img src={src} alt={`${project.title} ${index + 2}`} className={`${index % 5 === 0 ? "h-[58vh]" : "h-[38vh]"} w-full object-cover transition duration-[1800ms] hover:scale-[1.02]`} />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  );
}

